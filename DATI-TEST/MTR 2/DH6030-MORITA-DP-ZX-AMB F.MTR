        <Comment>Calibration Technician :: SLT
Classification of Instrument :: IP
Name of the Standard :: IEC62353-Direct

</Comment>
        <PlugInData PlugIn="ESA615">
          <ModuleSetup>
            <Module ID="1" Class="2" Leads="1" FirstLead="1">
              <Item Name="Module Code" Ord="1" Caption="A.P.Name" Required="True" Key="True">Funz.1</Item>
              <Item Name="Serial No." Ord="2" Caption="Serial No." Required="True" />
              <Item Name="Type" Ord="3" Caption="Type" />
            </Module>
          </ModuleSetup>
        </PlugInData>
        <ResultItem ElementID="2">
          <Status>Passed</Status>
          <Measurement Key="S1">
            <Description>Operator ID</Description>
            <Value Type="Text"></Value>
            <Status>Passed</Status>
            <StepType>6</StepType>
          </Measurement>
        </ResultItem>
        <ResultItem ElementID="3">
          <Status>Passed</Status>
          <ResultItem MTI="1" ElementID="4">
            <Status>Passed</Status>
            <Measurement Key="::1::BF_AC">
              <Description>Funz.1</Description>
              <Value Type="Float">0.5</Value>
              <Unit>uAAC</Unit>
