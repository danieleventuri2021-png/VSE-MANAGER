# Normalizza i fine riga: niente piu' diff "fantasma" per sola differenza CRLF/LF.
* text=auto

# Script/strumenti Linux: forza LF
*.sh text eol=lf
*.service text eol=lf
*.conf text eol=lf
*.md text eol=lf

# Script Windows: forza CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Output strumenti e dati di test: non normalizzare
*.mtr -text
*.MTR -text
*.dta binary
*.DTA binary

# Asset binari
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.xlsx binary
*.zip binary
*.ico binary
*.ttf binary
*.otf binary
